{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Edge: Debug Vite",
      "type": "msedge",
      "request": "launch",
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--user-data-dir=${workspaceFolder}/.vscode/vscode-edge-profile",
        "http://localhost:5173"
      ],
      "preLaunchTask": "vite-dev",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "vite:///*": "${workspaceFolder}/*"
      }
    }
  ]
}